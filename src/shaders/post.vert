// ─────────────────────────────────────────────────────────────
// post.vert ─ 풀스크린 포스트프로세싱용 정점 셰이더
// 화면을 덮는 사각형(quad)을 그대로 통과시키며 uv만 전달한다.
// ─────────────────────────────────────────────────────────────

varying vec2 vUv;

void main() {
  vUv = uv;
  gl_Position = vec4(position.xy, 0.0, 1.0);
}
